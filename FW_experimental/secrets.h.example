// ── TMEP.cz server URLs ───────────────────────────────────────────────────────
// Zkopíruj tento soubor jako secrets.h a vyplň své URL z tmep.cz:
//
//   cp secrets.h.example secrets.h
//
// Soubor secrets.h je v .gitignore — nebude zveřejněn na GitHubu.
// Jak zjistit URL: viz README.md sekce 3.
//
// Formát Batch CSV POST (jeden řádek = jedno měření):
//   YYYY-MM-DD HH:MM:SS;G1;G2;G3;voltage;rssi
//
//   Server 1 — počasí:      G1=teplota (°C), G2=relativní vlhkost (%), G3=tlak (hPa),
//                            voltage=napětí baterie (V), rssi=WiFi RSSI (dBm)
//   Server 2 — světlo/UV:   G1=ambient light (lux), G2=UV index, G3=absolutní vlhkost (g/m³),
//                            voltage=napětí baterie (V), rssi=WiFi RSSI (dBm)
//   Server 3 — diagnostika: G1=PCB teplota (°C), G2=počet výpadků napájení, G3=délka cyklu (s),
//                            voltage=napětí baterie (V), rssi=WiFi RSSI (dBm)

#ifdef TEST_MODE

// Testovací senzory na tmep.cz (pro vývoj)
const char serverName1[] = "https://xxxxxx-yyyyyy.tmep.cz";  // test: počasí (T, RH, P)
const char serverName2[] = "https://xxxxxx-yyyyyy.tmep.cz";  // test: světlo (ALS, UV, absH)
const char serverName3[] = "https://xxxxxx-yyyyyy.tmep.cz";  // test: diagnostika (pcbT, ploss, dur)

#else

// Produkční senzory na tmep.cz
const char serverName1[] = "https://xxxxxx-yyyyyy.tmep.cz";  // počasí (T, RH, P)
const char serverName2[] = "https://xxxxxx-yyyyyy.tmep.cz";  // světlo (ALS, UV, absH)
const char serverName3[] = "https://xxxxxx-yyyyyy.tmep.cz";  // diagnostika (pcbT, ploss, dur)

#endif
